# ===========================================
# DelipuCash Expo App Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# All client-accessible env vars must be prefixed with EXPO_PUBLIC_

# API Configuration
# Production API (use when running expo with --tunnel)
EXPO_PUBLIC_API_URL=https://delipucash-latest.vercel.app
# Local API (use when running expo with --localhost)
# EXPO_PUBLIC_API_URL=http://192.168.100.141:3000

# Tawk.to Live Chat (required for in-app live chat)
# Get these from https://dashboard.tawk.to → Administration → Chat Widget
# Use the EXACT IDs from the embed snippet, NOT from the URL bar
EXPO_PUBLIC_TAWK_PROPERTY_ID=
EXPO_PUBLIC_TAWK_WIDGET_ID=
# Optional: override WebView origin for Tawk domain checks (default: https://delipucash.app)
EXPO_PUBLIC_CHAT_BASE_URL=https://delipucash.app

# Node environment
NODE_ENV=development
