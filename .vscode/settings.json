{
  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "markdown.validate.enabled": false,
  "github.copilot.chat.terminalChatLocation": "terminal",
  "github.copilot.chat.copilotDebugCommand.enabled": false,
  "editor.formatOnSave": true,
  "files.exclude": {
    "**/.env": false
  }
}
