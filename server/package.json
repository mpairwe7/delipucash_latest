{
  "name": "delipucash-server",
  "version": "1.0.0",
  "main": "api/index.js",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun --watch index.js",
    "start": "bun index.js",
    "build": "prisma generate",
    "clean": "rm -rf node_modules/.cache dist .turbo",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate",
    "db:push": "bun prisma db push",
    "db:studio": "bun prisma studio",
    "db:reset": "bun prisma migrate reset",
    "db:seed": "bun prisma/seed.mjs",
    "seed:mock": "bun scripts/seed-mock-data.mjs",
    "lint": "bun run --bun eslint .",
    "test": "bun test"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1066.0",
    "@aws-sdk/s3-request-presigner": "^3.1066.0",
    "@prisma/adapter-pg": "7.4.0",
    "@prisma/client": "7.4.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@sentry/node": "^8.47.0",
    "@types/node": "^25.2.3",
    "@upstash/redis": "^1.34.3",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dotenv": "^16.6.1",
    "expo-server-sdk": "^3.14.0",
    "express": "^4.22.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.2.2",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.21.0",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.5",
    "papaparse": "^5.5.3",
    "pg": "8.17.2",
    "postgres": "^3.4.8",
    "serverless-http": "^4.0.0",
    "ts-node": "^10.9.2",
    "uuid": "^11.1.1"
